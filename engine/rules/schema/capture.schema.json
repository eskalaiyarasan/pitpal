{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine/rules/schema/capture.schema.json",
  "title": "Capture Schema",

  "$defs": {
    "Capture": {
      "type": "object",
      "required": ["Type", "SubType", "Param"],
      "properties": {
        "Type": {
          "type": "string",
          "const": "enum"
        },

        "SubType": {
          "type": "array",
          "enum": ["beyond", "opposite", "adjacent"]
        },
        "Plus": {
          "$ref": "engine/rules/schema/boolean.schema.json#/$defs/Bool"
        },
        "Param": {
          "$ref": "engine/rules/schema/parameter.schema.json#/$defs/Parameter"
        }
      },
      "additionalProperties": false
    }
  }
}
