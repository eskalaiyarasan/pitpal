{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine/rules/schema/kingzpit.schema.json",
  "title": "Algorithm Schema",

  "$defs": {
    "kingz": {
      "type": "object",
      "required": ["Type", "SubType", "Param"],
      "properties": {
        "Type": {
          "type": "string",
          "const": "array"
        },
        "SubType":{
          "type": "string",
          "const":"integer"
        },
        "Value": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "Param": {
          "$ref": "engine/rules/schema/parameter.schema.json#/$defs/Parameter"
        }
      },
      "additionalProperties": false
    }
  }
}
