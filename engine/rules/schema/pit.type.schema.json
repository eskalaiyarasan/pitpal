{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine/rules/schema/pit.type.schema.json",
  "title": "Game Parameter",

  "$defs": {
    "pitType": {
      "type": "object",
      "required": ["Type"],

      "properties": {
        "Type": {
          "type": "string",
          "const": "enum"
        },
        "SubType": {
          "type": "string",
          "enum": ["normal", "normalPlus"],
          "default": "normal"
        },
        "Value": {
          "$ref": "engine/rules/schema/integer.schema.json#/$defs/Integer"
        },
        "Param": {
          "$ref": "engine/rules/schema/parameter.schema.json#/$defs/Parameter"
        }
      },
      "additionalProperties": false
    }
  }
}
