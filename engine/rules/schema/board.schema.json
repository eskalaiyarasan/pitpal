{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine/rules/schema/board.schema.json",
  "title": "Board Schema",

  "$defs": {
    "Board": {
      "type": "object",
      "properties": {
        "pitType": {
          "$ref": "engine/rules/schema/pit.type.schema.json#/$defs/pitType"
        },
        "pitsPerSide": {
          "allOf": [
            { "$ref": "engine/rules/schema/integer.schema.json#/$defs/Integer" }
          ]
        },

        "nSide": {
          "allOf": [
            { "$ref": "engine/rules/schema/integer.schema.json#/$defs/Integer" }
          ]
        },

        "nSeeds": {
          "allOf": [
            { "$ref": "engine/rules/schema/integer.schema.json#/$defs/Integer" }
          ]
        },

        "kingzpits": {
          "allOf": [
            { "$ref": "engine/rules/schema/kingzpits.schema.json#/$defs/kingz" }
          ]
        }
      },

      "required": ["pitsPerSide", "nSide", "nSeeds"],
      "additionalProperties": false
    }
  }
}
