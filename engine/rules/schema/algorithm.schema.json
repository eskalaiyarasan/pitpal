{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "engine/rules/schema/algorithm.schema.json",
  "title": "Algorithm Schema",

  "$defs": {
    "Algorithm": {
      "type": "object",
      "required": ["Type", "SubType", "Param"],
      "properties": {
        "Type": {
          "type": "string",
          "const": "enum"
        },

        "SubType": {
          "type": "string",
          "enum": ["classic", "silver", "spiral", "modern"]
        },
        "Param": {
          "$ref": "engine/rules/schema/parameter.schema.json#/$defs/Parameter"
        }
      },
      "additionalProperties": false
    }
  }
}
